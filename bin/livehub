#!/usr/bin/env node
// livehub — install, uninstall, and manage the file-lock skill in any project.
//
// Usage:
//   livehub install   [<target-dir>]   copy files + wire .claude/settings.json
//   livehub uninstall [<target-dir>]   strip settings.json + remove copied files
//   livehub status    [<target-dir>]   show install state + active locks
//   livehub list      [<target-dir>]   list every locked file in the project
//   livehub release   <file>           force-release one file's lock
//   livehub purge-all [<target-dir>]   strip every marker from every file
//   livehub on | off  [<target-dir>]   toggle CLAUDE_FILE_LOCK kill-switch
//   livehub watch     [<target-dir>] [--once]   live TUI of active locks, refreshed every 1s
//   livehub doctor    [<target-dir>]   audit the tree for stale / unparseable / duplicate / orphan markers
//   livehub test      [<target-dir>]   simulate acquire / collision / release
//   livehub help                       this message

const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');

const PKG_ROOT = path.resolve(__dirname, '..');
const SRC_LOCK = path.join(PKG_ROOT, 'lock');
const SRC_HOOKS = path.join(PKG_ROOT, 'hooks');
const SRC_SKILL = path.join(PKG_ROOT, 'skill');

const argv = process.argv.slice(2);
const cmd = argv[0] || 'help';
const targetArg = argv[1];

function resolveTarget(arg) {
  return path.resolve(arg || process.cwd());
}

function paths(target) {
  return {
    target,
    install: path.join(target, '.livehub'),
    installLock: path.join(target, '.livehub/lock'),
    installHooks: path.join(target, '.livehub/hooks'),
    settings: path.join(target, '.claude/settings.json'),
    skillDir: path.join(target, '.claude/skills/file-lock'),
  };
}

function copyDir(src, dst) {
  fs.mkdirSync(dst, { recursive: true });
  for (const ent of fs.readdirSync(src, { withFileTypes: true })) {
    const s = path.join(src, ent.name);
    const d = path.join(dst, ent.name);
    if (ent.isDirectory()) copyDir(s, d);
    else { fs.copyFileSync(s, d); fs.chmodSync(d, ent.name.endsWith('.mjs') ? 0o755 : 0o644); }
  }
}

function readSettings(p) {
  if (!fs.existsSync(p)) return {};
  return JSON.parse(fs.readFileSync(p, 'utf-8'));
}
function writeSettings(p, s) {
  fs.mkdirSync(path.dirname(p), { recursive: true });
  fs.writeFileSync(p, JSON.stringify(s, null, 2) + '\n');
}

function isLivehubHook(h) {
  return typeof h?.command === 'string'
    && (h.command.includes('/livehub/hooks/file-lock-') || h.command.includes('.livehub/hooks/file-lock-'));
}

function injectHook(hooks, event, matcher, scriptRel, timeout) {
  hooks[event] = hooks[event] || [];
  let group = matcher
    ? hooks[event].find(g => g.matcher === matcher)
    : hooks[event].find(g => !g.matcher);
  if (!group) {
    group = matcher ? { matcher, hooks: [] } : { hooks: [] };
    hooks[event].push(group);
  }
  group.hooks = group.hooks || [];
  // Replace any prior livehub entry for this script (handles re-installs).
  group.hooks = group.hooks.filter(h => !(typeof h.command === 'string' && h.command.includes(path.basename(scriptRel))));
  group.hooks.unshift({
    type: 'command',
    command: `sh -c 'exec node "\${CLAUDE_PROJECT_DIR:-.}/${scriptRel}"'`,
    timeout,
  });
}

function cmdHelp() {
  const src = fs.readFileSync(__filename, 'utf-8').split('\n');
  const start = src.findIndex(l => l.startsWith('// livehub'));
  const end = src.findIndex((l, i) => i > start && !l.startsWith('//'));
  console.log(src.slice(start, end).join('\n').replace(/^\/\/ ?/gm, ''));
}

function cmdInstall() {
  const t = resolveTarget(targetArg);
  const p = paths(t);

  // Copy lock + hooks INTO the target so it's portable across machines/checkouts.
  // Settings.json references them via ${CLAUDE_PROJECT_DIR}-relative paths.
  copyDir(SRC_LOCK, p.installLock);
  copyDir(SRC_HOOKS, p.installHooks);
  copyDir(SRC_SKILL, p.skillDir);
  console.log(`copied to ${path.relative(t, p.install)}/ and ${path.relative(t, p.skillDir)}/`);

  const s = readSettings(p.settings);
  s.hooks = s.hooks || {};
  injectHook(s.hooks, 'PreToolUse',  'Write|Edit|MultiEdit', '.livehub/hooks/file-lock-pre.mjs',   5000);
  injectHook(s.hooks, 'PostToolUse', 'Write|Edit|MultiEdit', '.livehub/hooks/file-lock-post.mjs',  5000);
  injectHook(s.hooks, 'SessionEnd',  null,                   '.livehub/hooks/file-lock-purge.mjs', 5000);
  writeSettings(p.settings, s);
  console.log(`wired ${path.relative(t, p.settings)} → ${PKG_ROOT}`);

  console.log('\ninstalled. run `livehub status` to verify, or `livehub test` to smoke-test.');
}

function cmdUninstall() {
  const t = resolveTarget(targetArg);
  const p = paths(t);

  if (fs.existsSync(p.settings)) {
    const s = readSettings(p.settings);
    for (const event of ['PreToolUse', 'PostToolUse', 'SessionEnd']) {
      for (const group of s.hooks?.[event] || []) {
        group.hooks = (group.hooks || []).filter(h => !isLivehubHook(h));
      }
    }
    writeSettings(p.settings, s);
    console.log(`stripped hooks from ${path.relative(t, p.settings)}`);
  }
  if (fs.existsSync(p.install)) {
    fs.rmSync(p.install, { recursive: true, force: true });
    console.log(`removed ${path.relative(t, p.install)}/`);
  }
  if (fs.existsSync(p.skillDir)) {
    fs.rmSync(p.skillDir, { recursive: true, force: true });
    console.log(`removed ${path.relative(t, p.skillDir)}/`);
  }
  console.log('\nuninstalled.');
}

function cmdStatus() {
  const t = resolveTarget(targetArg);
  const p = paths(t);
  const filesPresent = ['file-lock-pre.mjs', 'file-lock-post.mjs', 'file-lock-purge.mjs']
    .every(f => fs.existsSync(path.join(p.installHooks, f)))
    && fs.existsSync(path.join(p.installLock, 'file-lock.cjs'));
  let wired = false, kill = false;
  if (fs.existsSync(p.settings)) {
    const s = readSettings(p.settings);
    const flatten = a => (a || []).flatMap(g => g.hooks || []);
    wired = [
      ...flatten(s.hooks?.PreToolUse),
      ...flatten(s.hooks?.PostToolUse),
      ...flatten(s.hooks?.SessionEnd),
    ].some(isLivehubHook);
    kill = s.env?.CLAUDE_FILE_LOCK === '0';
  }
  console.log(`target              : ${t}`);
  console.log(`files installed     : ${filesPresent ? 'yes (.livehub/)' : 'NO — run `install`'}`);
  console.log(`settings.json wired : ${wired ? 'yes' : 'NO — run `install`'}`);
  console.log(`kill switch         : ${kill ? 'OFF (CLAUDE_FILE_LOCK=0)' : 'on'}`);
  console.log('');
  if (filesPresent) cmdList();
}

function loadLock(t) {
  const p = path.join(t, '.livehub/lock/file-lock.cjs');
  if (!fs.existsSync(p)) die(`not installed at ${t} — run \`livehub install\` first`);
  return require(p);
}

function cmdList() {
  const t = resolveTarget(targetArg);
  const lock = loadLock(t);
  const all = lock.listLocks(t);
  if (!all.length) return console.log('(no active locks)');
  console.log(`active locks: ${all.length}`);
  for (const l of all) {
    const age = Math.floor((Date.now() - new Date(l.startedAt || 0).getTime()) / 1000);
    console.log(`  ${l.target}\n    agent=${l.agentId}  age=${age}s  reason=${l.reason || '-'}`);
  }
}

function cmdRelease() {
  const file = argv[1];
  if (!file) return die('usage: livehub release <file>');
  const t = resolveTarget();
  const lock = loadLock(t);
  console.log(lock.releaseLock(path.resolve(file), {}));
}

function cmdPurgeAll() {
  const t = resolveTarget(targetArg);
  const lock = loadLock(t);
  const all = lock.listLocks(t);
  for (const l of all) lock.releaseLock(l.target, {});
  console.log(`purged ${all.length} lock(s)`);
}

function cmdToggle(value) {
  const t = resolveTarget(targetArg);
  const p = paths(t);
  const s = readSettings(p.settings);
  s.env = s.env || {};
  if (value === '0') s.env.CLAUDE_FILE_LOCK = '0';
  else delete s.env.CLAUDE_FILE_LOCK;
  writeSettings(p.settings, s);
  console.log(`file-lock is now ${value === '0' ? 'OFF' : 'ON'} for ${t}`);
}

function cmdTest() {
  const t = resolveTarget(targetArg);
  const p = paths(t);
  const pre = path.join(p.installHooks, 'file-lock-pre.mjs');
  const post = path.join(p.installHooks, 'file-lock-post.mjs');
  if (!fs.existsSync(pre)) return die(`not installed at ${t} — run \`livehub install\` first`);

  const tmp = path.join(require('os').tmpdir(), `livehub-test-${Date.now()}.js`);
  fs.writeFileSync(tmp, "function alpha() { return 1; }\nfunction beta() { return 2; }\n");
  const run = (script, sid, payload) => spawnSync('node', [script], {
    input: JSON.stringify({ session_id: sid, ...payload }),
    encoding: 'utf-8',
  });
  const write     = { tool_name: 'Write', tool_input: { file_path: tmp } };
  const editAlpha = { tool_name: 'Edit',  tool_input: { file_path: tmp, old_string: 'return 1;' } };
  const editBeta  = { tool_name: 'Edit',  tool_input: { file_path: tmp, old_string: 'return 2;' } };

  console.log('1. whole-file acquire (sess A)…');
  let r = run(pre, 'aaaaaaaa', write);
  console.log(`   exit=${r.status} ${r.status === 0 ? 'OK' : 'FAIL'}`);
  console.log('2. whole-file collision (sess B)…');
  r = run(pre, 'bbbbbbbb', write);
  console.log(`   exit=${r.status} ${r.status === 2 ? 'OK (blocked)' : 'FAIL'}`);
  console.log('3. release (sess A)…');
  r = run(post, 'aaaaaaaa', write);
  console.log(`   exit=${r.status} ${r.status === 0 ? 'OK' : 'FAIL'}`);
  console.log('4. semantic: A→alpha, B→beta (different nodes, both succeed)…');
  const rA = run(pre, 'aaaaaaaa', editAlpha).status;
  const rB = run(pre, 'bbbbbbbb', editBeta).status;
  console.log(`   A=${rA}  B=${rB}  ${rA === 0 && rB === 0 ? 'OK' : 'FAIL'}`);
  console.log('5. semantic collision: C→alpha while A still holds it…');
  r = run(pre, 'cccccccc', editAlpha);
  console.log(`   exit=${r.status} ${r.status === 2 ? 'OK (blocked)' : 'FAIL'}`);
  run(post, 'aaaaaaaa', editAlpha);
  run(post, 'bbbbbbbb', editBeta);
  console.log('6. markers stripped after release?');
  const left = fs.readFileSync(tmp, 'utf-8');
  console.log(`   ${left.includes('livehub lock:') ? 'FAIL — marker still present' : 'OK'}`);
  fs.unlinkSync(tmp);
}

// ---------------------------------------------------------------------------
// watch — live TUI of active locks, auto-refresh every 1s
// ---------------------------------------------------------------------------

/** Render one frame of the watch UI as a string. Pure: no terminal control,
 *  no clock side-effects beyond Date.now(). Easy to test directly. */
function renderWatchFrame(target, locks, now = Date.now()) {
  const lines = [];
  const ts = new Date(now).toISOString().replace('T', ' ').slice(0, 19);
  lines.push(`livehub watch · ${target} · ${ts} · ${locks.length} active lock(s)`);
  lines.push('');
  if (!locks.length) {
    lines.push('  (no active locks)');
    return lines.join('\n') + '\n';
  }
  // Oldest-first — surfaces likely-stale markers at the top.
  const sorted = [...locks].sort((a, b) => new Date(a.startedAt) - new Date(b.startedAt));
  const rows = sorted.map(l => ({
    path: path.relative(target, l.target) || l.target,
    agent: l.agentId,
    node: l.nodeId,
    age: Math.floor((now - new Date(l.startedAt).getTime()) / 1000) + 's',
    reason: l.reason || '-',
  }));
  const widthOf = (k, min) => Math.max(min, ...rows.map(r => String(r[k]).length));
  const wPath  = widthOf('path',  4);
  const wAgent = widthOf('agent', 5);
  const wNode  = widthOf('node',  4);
  const wAge   = widthOf('age',   3);
  lines.push(`  ${'PATH'.padEnd(wPath)}  ${'AGENT'.padEnd(wAgent)}  ${'NODE'.padEnd(wNode)}  ${'AGE'.padEnd(wAge)}  REASON`);
  for (const r of rows) {
    lines.push(`  ${r.path.padEnd(wPath)}  ${r.agent.padEnd(wAgent)}  ${r.node.padEnd(wNode)}  ${r.age.padEnd(wAge)}  ${r.reason}`);
  }
  return lines.join('\n') + '\n';
}

function cmdWatch() {
  const t = resolveTarget(targetArg === '--once' ? undefined : targetArg);
  const lock = loadLock(t);
  const once = argv.includes('--once');

  const draw = (clear) => {
    if (clear) process.stdout.write('\x1B[H\x1B[2J');
    process.stdout.write(renderWatchFrame(t, lock.listLocks(t)));
    if (!once) process.stdout.write('\nCtrl+C to exit.\n');
  };

  if (once) { draw(false); return; }

  /* c8 ignore start — interactive long-running loop is exercised manually,
     not in the test suite; the render itself is covered via --once. */
  process.stdout.write('\x1B[?25l');                       // hide cursor
  const cleanup = () => { process.stdout.write('\x1B[?25h\n'); process.exit(0); };
  process.on('SIGINT',  cleanup);
  process.on('SIGTERM', cleanup);
  draw(true);
  setInterval(() => draw(true), 1000);
  /* c8 ignore stop */
}

// ---------------------------------------------------------------------------
// doctor — one-shot health audit of marker state in the tree
// ---------------------------------------------------------------------------

const DOCTOR_STALE_MS = 10 * 60 * 1000;

/** Walk `dir` and collect anomalies in marker state. Pure: returns a list of
 *  `{ kind, target, ... }` objects. cmdDoctor formats and exits. */
function findDoctorAnomalies(dir, lockMod, now = Date.now()) {
  const anomalies = [];
  const SIDECAR = '.livehub-lock';
  const CRIT    = '.lh-crit';

  const walk = (d) => {
    let entries;
    try { entries = fs.readdirSync(d, { withFileTypes: true }); }
    /* c8 ignore next 2 — readdir errors on a child path are rare and non-fatal */
    catch { return; }
    for (const ent of entries) {
      const full = path.join(d, ent.name);
      if (ent.isDirectory()) {
        if (['node_modules', '.git', '.next'].includes(ent.name)) continue;
        if (ent.name === 'worktrees' && path.basename(d) === '.claude') continue;
        walk(full);
        continue;
      }
      // Orphan critical-section files — left over from a crashed acquire.
      if (ent.name.endsWith(CRIT)) {
        const stat = fs.statSync(full);
        anomalies.push({ kind: 'orphan-crit', target: full, ageMs: now - stat.mtimeMs });
        continue;
      }
      if (ent.name.endsWith(SIDECAR)) continue; // sidecar JSON has no parse-form anomalies
      // For commentable files, scan the top of the file for marker-shaped lines
      // that don't parse, plus duplicate / stale issues.
      const markers = lockMod._internal.readMarkers(full);
      // 1. Stale.
      for (const m of markers) {
        const age = now - new Date(m.startedAt).getTime();
        if (!isFinite(age) || age >= DOCTOR_STALE_MS) {
          anomalies.push({ kind: 'stale', target: full, ...m, ageMs: age });
        }
      }
      // 2. Duplicate (agentId, nodeId).
      const seen = new Map();
      for (const m of markers) {
        const key = `${m.agentId}::${m.nodeId}`;
        seen.set(key, (seen.get(key) || 0) + 1);
      }
      for (const [key, count] of seen) {
        if (count > 1) {
          const [agentId, nodeId] = key.split('::');
          anomalies.push({ kind: 'duplicate', target: full, agentId, nodeId, count });
        }
      }
      // 3. Unparseable: a top comment line that LOOKS like a marker (has the
      //    `livehub lock:` prefix immediately followed by an A= or agent=
      //    field token) but parseMarkerLine refuses. Likely a corrupted
      //    half-rewritten marker. The field-token gate avoids false positives
      //    on prose like `grep "livehub lock:"` in source comments.
      const MARKER_SHAPED_RE = /livehub lock:\s+(?:A=|agent=)/;
      let text;
      try { text = fs.readFileSync(full, 'utf-8'); }
      /* c8 ignore next 2 — read errors mid-walk are rare */
      catch { continue; }
      const headLines = text.split('\n').slice(0, 16);
      for (let i = 0; i < headLines.length; i++) {
        const line = headLines[i];
        if (MARKER_SHAPED_RE.test(line) && !lockMod._internal.parseMarkerLine(line)) {
          anomalies.push({ kind: 'unparseable', target: full, line: line.trim(), lineNo: i + 1 });
        }
      }
    }
  };
  walk(dir);
  return anomalies;
}

/** Format anomalies as a human-readable report. Pure (no I/O). */
function formatDoctorReport(target, anomalies, now = Date.now()) {
  const lines = [`livehub doctor: ${target}`, ''];
  if (!anomalies.length) {
    lines.push('  clean.');
    return lines.join('\n') + '\n';
  }
  for (const a of anomalies) {
    if (a.kind === 'stale') {
      const ageS = Math.floor(a.ageMs / 1000);
      lines.push(`[stale] ${a.target}`);
      lines.push(`  agent=${a.agentId} node=${a.nodeId} age=${ageS}s reason=${a.reason || '-'}`);
    } else if (a.kind === 'unparseable') {
      lines.push(`[unparseable] ${a.target}:${a.lineNo}`);
      lines.push(`  ${a.line}`);
    } else if (a.kind === 'duplicate') {
      lines.push(`[duplicate] ${a.target}`);
      lines.push(`  agent=${a.agentId} node=${a.nodeId} (${a.count} markers)`);
    } else if (a.kind === 'orphan-crit') {
      const ageS = Math.floor(a.ageMs / 1000);
      lines.push(`[orphan-crit] ${a.target}`);
      lines.push(`  age=${ageS}s`);
    }
  }
  lines.push('');
  lines.push(`${anomalies.length} anomaly${anomalies.length === 1 ? '' : ' or anomalies'} found.`);
  return lines.join('\n') + '\n';
}

function cmdDoctor() {
  const t = resolveTarget(targetArg);
  const lockMod = loadLock(t);
  const anomalies = findDoctorAnomalies(t, lockMod);
  process.stdout.write(formatDoctorReport(t, anomalies));
  process.exit(anomalies.length ? 1 : 0);
}

function die(msg) { console.error(msg); process.exit(1); }

const handlers = {
  help: cmdHelp,
  install: cmdInstall,
  uninstall: cmdUninstall,
  status: cmdStatus,
  list: cmdList,
  release: cmdRelease,
  'purge-all': cmdPurgeAll,
  on: () => cmdToggle('1'),
  off: () => cmdToggle('0'),
  test: cmdTest,
  watch: cmdWatch,
  doctor: cmdDoctor,
};
const fn = handlers[cmd];
if (!fn) { console.error(`unknown command: ${cmd}\n`); cmdHelp(); process.exit(1); }
fn();
