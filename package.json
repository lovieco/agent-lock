{
  "name": "agent-lock",
  "version": "0.1.0",
  "description": "A Claude Code skill that prevents two agents from editing the same file at once.",
  "bin": {
    "agent-lock": "bin/agent-lock"
  },
  "scripts": {
    "test": "node --test --test-reporter=spec 'test/**/*.test.cjs'",
    "coverage": "c8 --reporter=text --reporter=html --reporter=lcov --include='lock/**/*.cjs' --include='hooks/**/*.mjs' --include='bin/agent-lock' node --test 'test/**/*.test.cjs'",
    "coverage:check": "c8 --reporter=text --check-coverage --lines=100 --functions=100 --branches=100 --statements=100 --include='lock/**/*.cjs' --include='hooks/**/*.mjs' --include='bin/agent-lock' node --test 'test/**/*.test.cjs'"
  },
  "devDependencies": {
    "c8": "^10.1.3"
  }
}
